// Full production schema for PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  userResumes   UserResume[]
  notes         Note[]
  activities    Activity[]
  userProfile   UserProfile?
  conversations Conversation[]
  summaries     Summary[]
  scoutHistory  ScoutHistory[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String?
  title     String?  @default("AI Career Architect")
  bio       String?  @default("Building the future of tech careers.")
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserResume {
  id          String   @id @default(cuid())
  filename    String
  content     String   // Extracted or modified text content
  fileData    String?  // Base64 or URL
  mimeType    String   @default("application/pdf")
  score       Int?     @default(0)
  status      String   @default("Completed")
  tips        String?  // JSON string
  isSelected  Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  tags      String?  @default("#Note")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // job_search, resume_scan, video_summary
  title       String
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Summary {
  id          String   @id @default(cuid())
  userId      String
  url         String
  title       String
  content     String   // Markdown summary
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  messages  String   // JSON stringified history
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoutHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  type      String   // "jobs" | "research" | "products"
  data      String   // Stringified JSON payload Array/Object of the final results returned
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
